<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lexery.wiki-maintenance</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PATH_LEXERY_MONOREPO__/LLM Wiki/_system/scripts/run-maintenance-launchd.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__PATH_LEXERY_MONOREPO__/LLM Wiki</string>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>ThrottleInterval</key>
    <integer>300</integer>
    <key>StandardOutPath</key>
    <string>__PATH_LEXERY_MONOREPO__/LLM Wiki/_system/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__PATH_LEXERY_MONOREPO__/LLM Wiki/_system/logs/launchd-stderr.log</string>
</dict>
</plist>
